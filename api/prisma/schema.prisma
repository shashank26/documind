generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  createdAt DateTime   @default(now())

  documents Document[]
}

model Document {
  id        String   @id @default(uuid())
  userId    String
  fileName  String
  fileUrl   String
  status    DocumentStatus @default(UPLOADED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  tasks Task[]

  @@index([userId])
}


model Task {
  id          String   @id @default(uuid())
  documentId  String
  type        TaskType
  status      TaskStatus @default(PENDING)
  progress    Int       @default(0)
  errorMessage String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  document Document @relation(fields: [documentId], references: [id])

  @@index([documentId])
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum TaskType {
  DOCUMENT_PROCESSING
}

enum TaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}